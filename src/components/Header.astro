---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';

const basePath = import.meta.env.BASE_URL.endsWith('/')
	? import.meta.env.BASE_URL
	: `${import.meta.env.BASE_URL}/`;
---

<header class="site-header">
	<nav>
		<div class="brand">
			<a href={basePath}>{SITE_TITLE}</a>
		</div>
		<div class="nav-links">
			<HeaderLink href={basePath}>首页</HeaderLink>
			<HeaderLink href={`${basePath}blog`}>文章</HeaderLink>
			<HeaderLink href={`${basePath}projects`}>项目</HeaderLink>
			<HeaderLink href={`${basePath}about`}>关于</HeaderLink>
		</div>
		<div class="nav-actions" aria-label="site actions">
			<span>中文</span>
			<span>浅色</span>
		</div>
	</nav>
</header>
<style>
	.site-header {
		position: sticky;
		top: 0;
		z-index: 10;
		backdrop-filter: blur(18px);
		background: rgba(255, 255, 255, 0.82);
		border-bottom: 1px solid rgba(var(--line), 0.85);
	}

	nav {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 24px;
		padding: 18px 0;
	}

	.brand a {
		font-size: 1.1rem;
		font-weight: 700;
		letter-spacing: 0.04em;
		color: rgb(var(--black));
		text-decoration: none;
	}

	.nav-links,
	.nav-actions {
		display: flex;
		align-items: center;
		gap: 8px;
	}

	.nav-actions span {
		padding: 0.55rem 0.8rem;
		border-radius: 999px;
		background: rgba(var(--surface-2), 0.92);
		border: 1px solid rgba(var(--line), 0.9);
		font-size: 0.88rem;
		color: rgb(var(--gray-dark));
	}

	@media (max-width: 820px) {
		nav {
			flex-wrap: wrap;
		}

		.nav-links {
			order: 3;
			width: 100%;
			overflow: auto;
			padding-bottom: 4px;
		}

		.nav-actions {
			display: none;
		}
	}
</style>
