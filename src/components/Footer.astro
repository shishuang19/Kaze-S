---
const today = new Date();
---

<footer class="site-footer">
	<div class="footer-inner">
		<div>
			<p class="footer-brand">Kaze</p>
			<p class="footer-copy">一个受 diygod.cc 启发的 Astro 内容站原型。</p>
		</div>
		<div class="footer-meta">
			<p>© {today.getFullYear()} Kaze</p>
			<p><a href="/">首页</a> · <a href="/blog">文章</a> · <a href="/projects">项目</a></p>
		</div>
	</div>
</footer>
<style>
	.site-footer {
		padding: 56px 0 72px;
	}

	.footer-inner {
		width: min(1120px, calc(100% - 32px));
		margin: 0 auto;
		padding-top: 24px;
		border-top: 1px solid rgba(var(--line), 0.9);
		display: flex;
		justify-content: space-between;
		gap: 24px;
		color: rgb(var(--gray));
	}

	.footer-brand {
		margin: 0 0 8px;
		font-weight: 700;
		color: rgb(var(--black));
	}

	.footer-copy,
	.footer-meta p {
		margin: 0;
		font-size: 0.95rem;
	}

	.footer-meta {
		display: grid;
		gap: 8px;
		text-align: right;
	}

	.footer-meta a {
		color: inherit;
		text-decoration: none;
	}

	.footer-meta a:hover {
		color: rgb(var(--black));
	}

	@media (max-width: 720px) {
		.footer-inner {
			flex-direction: column;
		}

		.footer-meta {
			text-align: left;
		}
	}
</style>
