---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import PostCard from '../components/PostCard.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { getCollection } from 'astro:content';
import AvatarImage from '../assets/blog-placeholder-about.jpg';
import ProjectOne from '../assets/blog-placeholder-1.jpg';
import ProjectTwo from '../assets/blog-placeholder-2.jpg';
import ProjectThree from '../assets/blog-placeholder-4.jpg';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 3);

const projects = [
	{
		title: 'Follow',
		description: '一个聚合内容订阅与阅读体验的作品展示卡片原型。',
		href: 'https://example.com/follow',
		image: ProjectOne,
	},
	{
		title: 'Music',
		description: '面向个人品牌站的沉浸式项目展示布局示例。',
		href: 'https://example.com/music',
		image: ProjectTwo,
	},
	{
		title: 'Genshin',
		description: '带有封面图、简介和外链的项目宫格卡片样式。',
		href: 'https://example.com/genshin',
		image: ProjectThree,
	},
];
---

<!doctype html>
<html lang="zh-CN">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main class="page-shell home-page">
			<section class="hero panel">
				<div class="hero-copy">
					<p class="eyebrow">你好，很高兴见到你</p>
					<h1>做一个有作品感的个人网站。</h1>
					<p class="hero-lead">
						这里是一个受 diygod.cc 启发的 Astro 原型：首页强调作者介绍、精选文章和代表项目。
					</p>
					<p class="hero-text">
						整体风格偏内容型、留白充足、图片驱动，适合作为个人博客、作品集或独立开发者主页的起点。
					</p>
					<ul class="social-pills">
						<li><a href="https://github.com" target="_blank" rel="noreferrer">GitHub</a></li>
						<li><a href="https://x.com" target="_blank" rel="noreferrer">X</a></li>
						<li><a href="mailto:hello@example.com">Email</a></li>
						<li><a href="/rss.xml">RSS</a></li>
					</ul>
				</div>
				<div class="hero-art">
					<img src={AvatarImage.src} alt="avatar" />
				</div>
			</section>

			<section class="section-block">
				<div class="section-heading">
					<div>
						<p class="eyebrow">精选文章</p>
						<h2>最近写了什么</h2>
					</div>
					<a class="section-link" href="/blog">查看所有文章</a>
				</div>
				<div class="post-list">
					{posts.map((post) => <PostCard post={post} />)}
				</div>
			</section>

			<section class="section-block">
				<div class="section-heading">
					<div>
						<p class="eyebrow">项目作品</p>
						<h2>正在做的项目</h2>
					</div>
					<a class="section-link" href="/projects">查看所有项目</a>
				</div>
				<div class="project-grid">
					{projects.map((project) => <ProjectCard {...project} />)}
				</div>
			</section>
		</main>
		<Footer />
	</body>
</html>
